#include <stdio.h>
#include <stdbool.h>

int main() {
    int n, m, i, j;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter number of resources: ");
    scanf("%d", &m);

    int alloc[10][10], max[10][10], need[10][10];
    int avail[10];

    // Allocation matrix
    printf("Enter allocation matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            scanf("%d", &alloc[i][j]);
        }
    }

    // Maximum matrix
    printf("Enter maximum matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            scanf("%d", &max[i][j]);
        }
    }

    // Available resources
    printf("Enter available resources:\n");
    for(i = 0; i < m; i++) {
        scanf("%d", &avail[i]);
    }

    // Need = Max - Allocation
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            need[i][j] = max[i][j] - alloc[i][j];
        }
    }

    bool executed[10];
    for(i = 0; i < n; i++) {
        executed[i] = false;
    }

    int safe[10];
    int count = 0;

    // Main logic
    while(count < n) {
        int found = 0;

        for(i = 0; i < n; i++) {

            if(executed[i] == false) {

                int flag = 1;

                for(j = 0; j < m; j++) {
                    if(need[i][j] > avail[j]) {
                        flag = 0;
                        break;
                    }
                }

                if(flag == 1) {
                    // Release resources
                    for(j = 0; j < m; j++) {
                        avail[j] += alloc[i][j];
                    }

                    safe[count++] = i;
                    executed[i] = true;
                    found = 1;
                }
            }
        }

        if(found == 0) {
            printf("System is not safe\n");
            return 0;
        }
    }

    // Print safe sequence
    printf("Safe sequence: ");
    for(i = 0; i < n; i++) {
        printf("P%d ", safe[i]);
    }

    return 0;
}
