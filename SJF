#include<stdio.h>

int main(){
    int i,j,n;
    int bt[10], wt[10], tat[10], p[10];
    int total_wt=0, total_tat=0;
    float avg_wt, avg_tat;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    // Input
    for(i=0;i<n;i++){
        printf("Enter Burst Time for P%d: ",i+1);
        scanf("%d",&bt[i]);
        p[i] = i+1;
    }

    // Sorting (ascending burst time)
    for(i=0;i<n-1;i++){
        for(j=0;j<n-i-1;j++){
            if(bt[j] > bt[j+1]){
                int temp;

                temp = bt[j];
                bt[j] = bt[j+1];
                bt[j+1] = temp;

                temp = p[j];
                p[j] = p[j+1];
                p[j+1] = temp;
            }
        }
    }

    // Waiting Time
    wt[0] = 0;
    for(i=1;i<n;i++){
        wt[i] = wt[i-1] + bt[i-1];
    }

    // Turnaround Time
    for(i=0;i<n;i++){
        tat[i] = wt[i] + bt[i];
    }

    // Total
    for(i=0;i<n;i++){
        total_wt += wt[i];
        total_tat += tat[i];
    }

    avg_wt = (float)total_wt/n;
    avg_tat = (float)total_tat/n;

    // Output
    printf("\nP\tBT\tWT\tTAT\n");
    for(i=0;i<n;i++){
        printf("P%d\t%d\t%d\t%d\n",p[i],bt[i],wt[i],tat[i]);
    }

    printf("\nAvg WT = %.2f",avg_wt);
    printf("\nAvg TAT = %.2f",avg_tat);

    return 0;
}
